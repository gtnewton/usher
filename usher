#!/usr/bin/env bash
#
# usher — quick local HTTPS dev server backed by Caddy, with optional
#             PHP-FPM support. All working files live in a private mktemp
#             directory; nothing is ever written into the folder being served.
#
# Usage:
#   usher [--port PORT] [DIR]        Serve DIR (defaults to configured root).
#   usher [--port PORT] NAME         Serve the directory saved under bookmark NAME.
#   usher [--port PORT] --pick        Pick a folder graphically, then serve it.
#   usher --set-default [DIR]        Set the default root (graphical picker if no DIR).
#   usher --bookmark NAME [DIR]      Save a bookmark (graphical picker if no DIR).
#   usher --new-bookmark             Create a bookmark via graphical prompts.
#   usher --unbookmark NAME          Remove a bookmark.
#   usher --bookmarks                List all bookmarks.
#   usher --stop [PORT]              Stop a background server (all if no PORT given).
#   usher --status                   Report all running background servers.
#   usher install-extension          Install the GNOME Shell top-bar extension.
#   usher uninstall-extension        Remove the GNOME Shell top-bar extension.
#   usher -h | --help                Show this help.
#
# To serve a local subdirectory that shares a name with a bookmark, use ./name.
#
# Settings live in ~/.config/usher/config (DEFAULT_ROOT, PORT, MIME_TYPES,
# CADDY_EXTRA). PORT sets the base port; usher auto-picks the next free port
# above it when starting. Certificates live in ~/.local/share/usher/ (cert.pem,
# key.pem); without them Caddy falls back to its own internal CA.

set -euo pipefail

# ── Paths & defaults ─────────────────────────────────────────────────────────

# In-script fallback default root. The installer and --set-default normally
# persist this to the config file below, which overrides this line.
DEFAULT_ROOT=""

# Base port. usher auto-picks the first free port at or above this value
# unless --port is given explicitly. Persisted overrides come from the config.
PORT="${PORT:-8443}"

DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/usher"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/usher"
CONFIG_FILE="${CONFIG_DIR}/config"
BOOKMARKS_FILE="${CONFIG_DIR}/bookmarks"
RUN_DIR="${XDG_RUNTIME_DIR:-/tmp}/usher"

CERT_FILE="${DATA_DIR}/cert.pem"
KEY_FILE="${DATA_DIR}/key.pem"

# Persisted settings may override DEFAULT_ROOT, PORT, CERT_FILE, KEY_FILE.
# shellcheck source=/dev/null
[[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE"

# State referenced by the cleanup trap; populated once a server starts.
WORK_DIR=""
CADDY_PID=""
PHP_PID_FILE=""

# ── Helpers ──────────────────────────────────────────────────────────────────

usage() {
    sed -n '3,27p' "$0" | sed 's/^# \{0,1\}//'
}

notify() {
    # Desktop notification when available (for background/GUI use); always echo.
    local title="$1" body="${2:-}"
    if command -v notify-send >/dev/null 2>&1; then
        notify-send -a usher "$title" "$body" 2>/dev/null || true
    fi
    echo "${title}${body:+: $body}"
}

# Find the lowest free TCP port at or above $base (probes up to 20 candidates).
pick_free_port() {
    local base="${1:-8443}" port
    for port in $(seq "$base" $((base + 19))); do
        ss -tlnH 2>/dev/null | grep -qF ":${port}" || { echo "$port"; return 0; }
    done
    echo "usher: no free port found in range ${base}–$((base + 19))" >&2
    return 1
}

# Emit machine-readable state for a port to ${RUN_DIR}/state-PORT.json.
# This is the contract the future GNOME extension will watch via Gio.FileMonitor.
write_state() {
    local status="$1" root="${2:-}" port="${3:-$PORT}" caddy_pid="${4:-0}"
    mkdir -p "$RUN_DIR"
    jq -n \
        --arg    status    "$status" \
        --arg    root      "$root" \
        --argjson port     "$port" \
        --argjson caddy_pid "${caddy_pid:-0}" \
        --arg    ts        "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        '{status:$status, root:$root, port:$port, caddy_pid:$caddy_pid, updated_at:$ts}' \
        > "${RUN_DIR}/state-${port}.json"
}

# Set (count>0) or clear (count=0) the dock badge.
# All instances share one badge-keeper process tracked in ${RUN_DIR}/badge.pid;
# each start/stop kills the old keeper and restarts it with the current count.
launcher_badge() {
    local count="${1:-0}"
    command -v python3 >/dev/null 2>&1 || return 0
    [[ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ]] && return 0

    local badge_pid_file="${RUN_DIR}/badge.pid"
    if [[ -f "$badge_pid_file" ]]; then
        kill "$(< "$badge_pid_file")" 2>/dev/null || true
        rm -f "$badge_pid_file"
    fi

    if [[ "$count" -gt 0 ]]; then
        python3 - "$count" <<'PYEOF' 2>/dev/null &
import gi, signal, sys
gi.require_version('GLib', '2.0')
gi.require_version('Gio', '2.0')
from gi.repository import GLib, Gio
count = int(sys.argv[1])
bus = Gio.bus_get_sync(Gio.BusType.SESSION, None)
bus.emit_signal(None,
    '/com/canonical/unity/launcherentry/usher',
    'com.canonical.Unity.LauncherEntry', 'Update',
    GLib.Variant('(sa{sv})', ('application://usher.desktop',
        {'count': GLib.Variant('x', count), 'count-visible': GLib.Variant('b', True)})))
loop = GLib.MainLoop()
signal.signal(signal.SIGTERM, lambda *_: loop.quit())
signal.signal(signal.SIGINT, lambda *_: loop.quit())
loop.run()
PYEOF
        mkdir -p "$RUN_DIR"
        echo $! > "$badge_pid_file"
    fi
}

# Persist a key=value pair to the config file, replacing any existing entry.
update_config() {
    local key="$1" val="$2"
    mkdir -p "$CONFIG_DIR"
    touch "$CONFIG_FILE"
    if grep -q "^${key}=" "$CONFIG_FILE"; then
        sed -i "s|^${key}=.*|${key}=\"${val}\"|" "$CONFIG_FILE"
    else
        printf '%s="%s"\n' "$key" "$val" >> "$CONFIG_FILE"
    fi
}

# Look up a bookmark by name; prints the path and returns 0, or returns 1 if not found.
lookup_bookmark() {
    local name="$1" line
    [[ ! -f "$BOOKMARKS_FILE" ]] && return 1
    line="$(grep -m1 "^${name}=" "$BOOKMARKS_FILE" 2>/dev/null)" || return 1
    printf '%s' "${line#*=}"
}

set_bookmark() {
    local name="${1:-}" dir="${2:-}"
    if [[ -z "$name" || ! "$name" =~ ^[a-zA-Z0-9_-]+$ ]]; then
        echo "usher: bookmark name must contain only letters, digits, hyphens, and underscores." >&2
        exit 1
    fi
    [[ -z "$dir" ]] && dir="$(pick_dir "usher — choose folder for '${name}'")" || true
    dir="${dir/#\~/$HOME}"
    if [[ -z "$dir" ]]; then
        echo "No folder given; bookmark unchanged."
        exit 1
    fi
    if [[ ! -d "$dir" ]]; then
        notify "usher" "Not a directory: $dir"
        exit 1
    fi
    mkdir -p "$CONFIG_DIR"
    if [[ ! -f "$BOOKMARKS_FILE" ]]; then
        printf '# usher bookmarks — one bookmark per line: name=/path/to/folder\n' > "$BOOKMARKS_FILE"
    fi
    if grep -q "^${name}=" "$BOOKMARKS_FILE"; then
        sed -i "s|^${name}=.*|${name}=${dir}|" "$BOOKMARKS_FILE"
        notify "usher bookmark updated" "${name} → ${dir}"
    else
        printf '%s=%s\n' "$name" "$dir" >> "$BOOKMARKS_FILE"
        notify "usher bookmark added" "${name} → ${dir}"
    fi
}

new_bookmark() {
    if ! command -v zenity >/dev/null 2>&1; then
        echo "usher: zenity is required for graphical bookmark creation." >&2
        exit 1
    fi
    local name
    name="$(zenity --entry \
        --title="usher — new bookmark" \
        --text="Bookmark name (letters, digits, hyphens, underscores):" \
        2>/dev/null)" || exit 0
    [[ -z "$name" ]] && exit 0
    set_bookmark "$name"
}

remove_bookmark_gui() {
    [[ ! -f "$BOOKMARKS_FILE" ]] && { notify "usher" "No bookmarks to remove."; return; }
    local -a names=()
    while IFS='=' read -r name _; do
        [[ -n "$name" ]] && names+=("$name")
    done < <(grep "^[^#=]" "$BOOKMARKS_FILE" 2>/dev/null)
    [[ ${#names[@]} -eq 0 ]] && { notify "usher" "No bookmarks to remove."; return; }
    local chosen
    chosen="$(zenity --list \
        --title="usher — remove bookmark" \
        --text="Select a bookmark to remove:" \
        --column="Bookmark" \
        --width=300 \
        --height=$(( 150 + ${#names[@]} * 50 )) \
        "${names[@]}" 2>/dev/null)" || return 0
    [[ -n "$chosen" ]] && remove_bookmark "$chosen" && notify "usher" "Bookmark '${chosen}' removed."
}

remove_bookmark() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then
        echo "usher: --unbookmark requires a name." >&2
        exit 1
    fi
    if [[ ! -f "$BOOKMARKS_FILE" ]] || ! grep -q "^${name}=" "$BOOKMARKS_FILE"; then
        echo "usher: no bookmark named '${name}'." >&2
        exit 1
    fi
    sed -i "/^${name}=/d" "$BOOKMARKS_FILE"
    echo "Bookmark '${name}' removed."
}

list_bookmarks() {
    if [[ ! -f "$BOOKMARKS_FILE" ]] || ! grep -q "^[^#]" "$BOOKMARKS_FILE"; then
        echo "No bookmarks set.  Use: usher --bookmark NAME [DIR]"
        return
    fi
    grep "^[^#]" "$BOOKMARKS_FILE" | while IFS='=' read -r name path; do
        printf '  %-20s %s\n' "$name" "$path"
    done
}

# Graphical directory picker; prints the chosen path or returns non-zero.
pick_dir() {
    local title="${1:-usher — choose a folder to serve}"
    if command -v zenity >/dev/null 2>&1; then
        zenity --file-selection --directory --title="$title" 2>/dev/null
    else
        local dir
        read -rp "Folder: " dir
        [[ -n "$dir" ]] && printf '%s\n' "${dir/#\~/$HOME}"
    fi
}

set_default() {
    local dir="${1:-}"
    [[ -z "$dir" ]] && dir="$(pick_dir 'usher — choose default folder to serve')" || true
    dir="${dir/#\~/$HOME}"
    if [[ -z "$dir" ]]; then
        echo "No folder given; default unchanged."
        exit 1
    fi
    if [[ ! -d "$dir" ]]; then
        notify "usher" "Not a directory: $dir"
        exit 1
    fi
    update_config DEFAULT_ROOT "$dir"
    notify "usher default set" "$dir"
}

# Returns 0 if a usher server is running on the given port.
is_running_on() {
    local port="$1" pid_file
    pid_file="${RUN_DIR}/usher-${port}.pid"
    [[ -f "$pid_file" ]] && kill -0 "$(< "$pid_file")" 2>/dev/null
}

# Prints each live port on its own line; returns 1 if none are running.
list_running() {
    [[ -d "$RUN_DIR" ]] || return 1
    local f caddy_pid port status any=false
    for f in "${RUN_DIR}"/state-*.json; do
        [[ -f "$f" ]] || continue
        status="$(jq -r '.status' "$f" 2>/dev/null)" || continue
        [[ "$status" == "running" ]] || continue
        port="$(jq -r '.port' "$f" 2>/dev/null)" || continue
        caddy_pid="$(jq -r '.caddy_pid // 0' "$f" 2>/dev/null)" || continue
        [[ "$caddy_pid" -gt 0 ]] && kill -0 "$caddy_pid" 2>/dev/null || continue
        echo "$port"
        any=true
    done
    [[ "$any" == true ]]
}

stop_server() {
    local target_port="${1:-}"

    if [[ -n "$target_port" ]]; then
        local state_file="${RUN_DIR}/state-${target_port}.json"
        local pid_file="${RUN_DIR}/usher-${target_port}.pid"
        local caddy_pid
        caddy_pid="$(jq -r '.caddy_pid // 0' "$state_file" 2>/dev/null || echo 0)"
        [[ "$caddy_pid" -gt 0 ]] && kill "$caddy_pid" 2>/dev/null || true
        [[ -f "$pid_file" ]] && kill "$(< "$pid_file")" 2>/dev/null || true
        write_state stopped "" "$target_port"
        rm -f "$pid_file"
        local count; count=$(list_running 2>/dev/null | wc -l) || count=0
        launcher_badge "$count"
        notify "usher stopped" "port ${target_port}"
        return
    fi

    local -a ports=()
    local f port status
    for f in "${RUN_DIR}"/state-*.json; do
        [[ -f "$f" ]] || continue
        status="$(jq -r '.status' "$f" 2>/dev/null)" || continue
        [[ "$status" == "running" ]] || continue
        port="$(jq -r '.port' "$f" 2>/dev/null)" || continue
        ports+=("$port")
    done
    if [[ ${#ports[@]} -eq 0 ]]; then
        echo "No running background servers found."
        return
    fi
    for port in "${ports[@]}"; do
        stop_server "$port"
    done
}

status() {
    local -a ports
    mapfile -t ports < <(list_running 2>/dev/null || true)
    if [[ ${#ports[@]} -eq 0 ]]; then
        echo "usher is not running."
        return
    fi
    local port state_file root caddy_pid
    for port in "${ports[@]}"; do
        state_file="${RUN_DIR}/state-${port}.json"
        root=""; caddy_pid=0
        if [[ -f "$state_file" ]]; then
            root="$(jq -r '.root' "$state_file")"
            caddy_pid="$(jq -r '.caddy_pid // 0' "$state_file")"
        fi
        printf 'usher running  https://127.0.0.1:%s  %s  (Caddy PID %s)\n' \
            "$port" "${root:-?}" "$caddy_pid"
    done
}

gui_panel() {
    command -v zenity >/dev/null 2>&1 || { notify "usher" "zenity is required for the GUI panel."; exit 1; }

    local -a running_ports items
    local status_text port state_file rdir n choice bm_name display_name

    while true; do
        running_ports=()
        items=()
        mapfile -t running_ports < <(list_running 2>/dev/null || true)

        if [[ ${#running_ports[@]} -gt 0 ]]; then
            if [[ ${#running_ports[@]} -eq 1 ]]; then
                port="${running_ports[0]}"
                state_file="${RUN_DIR}/state-${port}.json"
                rdir="$(jq -r '.root' "$state_file" 2>/dev/null || echo '?')"
                status_text="Running: https://127.0.0.1:${port}\n${rdir}"
            else
                status_text="${#running_ports[@]} servers running"
            fi
            for port in "${running_ports[@]}"; do
                rdir="$(jq -r '.root' "${RUN_DIR}/state-${port}.json" 2>/dev/null || echo '')"
                bm_name="$(grep -F "=${rdir}" "$BOOKMARKS_FILE" 2>/dev/null | head -1 | cut -d= -f1 || true)"
                display_name="${bm_name:-${rdir##*/}}"
                items+=("Stop :${port} [${display_name}]")
            done
        else
            status_text="Server is not running."
            [[ -n "${DEFAULT_ROOT:-}" ]] && items+=("Serve: ${DEFAULT_ROOT##*/}")
            if [[ -f "$BOOKMARKS_FILE" ]]; then
                while IFS='=' read -r name _; do
                    [[ -n "$name" ]] && items+=("$name")
                done < <(grep "^[^#=]" "$BOOKMARKS_FILE")
            fi
            items+=("Serve a folder…")
        fi
        items+=("Add bookmark…" "Remove bookmark…" "Set default folder…")

        n=${#items[@]}
        choice=$(zenity --list \
            --title="usher" \
            --text="$status_text" \
            --column="──────────────────" \
            --width=300 \
            --height=$(( 250 + n * 65 )) \
            "${items[@]}" 2>/dev/null) || return 0
        [[ -z "$choice" ]] && return 0

        case "$choice" in
            "Stop :"*)
                local _p="${choice#Stop :}"; stop_server "${_p%% *}" ;;
            "Serve: "*)
                serve "$DEFAULT_ROOT" &
                return 0 ;;
            "Serve a folder…")
                local dir
                dir="$(pick_dir)" || continue
                if [[ -n "$dir" ]]; then
                    serve "$dir" &
                    return 0
                fi ;;
            "Add bookmark…")
                new_bookmark ;;
            "Remove bookmark…")
                remove_bookmark_gui ;;
            "Set default folder…")
                set_default ;;
            *)
                local bm_path
                bm_path="$(lookup_bookmark "$choice")" || { notify "usher" "Unknown bookmark: $choice"; continue; }
                serve "$bm_path" &
                return 0 ;;
        esac
    done
}

install_extension() {
    local uuid="usher@gtnewton.github.com"
    local src="${DATA_DIR}/extension"
    local dest="${XDG_DATA_HOME:-$HOME/.local/share}/gnome-shell/extensions/${uuid}"
    if [[ ! -d "$src" ]]; then
        echo "usher: extension source not found at ${src}." >&2
        echo "       Re-run install.sh from the usher repository to install it." >&2
        exit 1
    fi
    # Remove then re-create so the shell's directory monitor fires for a new entry.
    rm -rf "$dest"
    mkdir -p "$dest"
    cp -r "${src}/." "$dest/"
    if [[ -d "${dest}/schemas" ]] && command -v glib-compile-schemas >/dev/null 2>&1; then
        glib-compile-schemas "${dest}/schemas"
    fi
    echo "Extension installed to ${dest}"
    if command -v gnome-extensions >/dev/null 2>&1; then
        local i
        for i in $(seq 1 20); do
            gnome-extensions list 2>/dev/null | grep -qx "$uuid" && break
            sleep 0.25
        done
        if gnome-extensions enable "$uuid" 2>/dev/null; then
            echo "Extension enabled — it will appear in the top bar shortly."
        else
            echo "Extension installed. Log out and back in to activate it,"
            echo "or run: gnome-extensions enable ${uuid}"
        fi
    else
        echo "Extension installed. Log out and back in to activate it."
    fi
}

uninstall_extension() {
    local uuid="usher@gtnewton.github.com"
    if command -v gnome-extensions >/dev/null 2>&1; then
        gnome-extensions uninstall "$uuid" 2>/dev/null \
            && echo "Extension removed." \
            && return
    fi
    rm -rf "${XDG_DATA_HOME:-$HOME/.local/share}/gnome-shell/extensions/${uuid}"
    echo "Extension removed."
}

cleanup() {
    [[ -n "$CADDY_PID" ]] && kill "$CADDY_PID" 2>/dev/null || true
    [[ -n "$PHP_PID_FILE" && -f "$PHP_PID_FILE" ]] && kill "$(cat "$PHP_PID_FILE")" 2>/dev/null || true
    [[ -n "$WORK_DIR" && -d "$WORK_DIR" ]] && rm -rf "$WORK_DIR"
    rm -f "${RUN_DIR}/usher-${PORT}.pid"
    write_state stopped "" "$PORT"
    local count; count=$(list_running 2>/dev/null | wc -l) || count=0
    launcher_badge "$count"
}

# ── Core: serve a directory ──────────────────────────────────────────────────

serve() {
    local root="${1/#\~/$HOME}"

    # Auto-pick the first free port at or above the base unless pinned by --port.
    if [[ "${PORT_EXPLICIT:-false}" != true ]]; then
        PORT="$(pick_free_port "${PORT:-8443}")" || exit 1
    fi

    if [[ ! -d "$root" ]]; then
        notify "usher" "Not a directory: $root"
        exit 1
    fi
    if is_running_on "$PORT"; then
        notify "usher" "Port ${PORT} already in use.  Stop it first: usher --stop ${PORT}"
        exit 1
    fi
    if ! command -v caddy >/dev/null 2>&1; then
        notify "usher" "Caddy is not installed."
        exit 1
    fi

    # Private working directory; cleaned up on exit. Nothing lands in $root.
    WORK_DIR="$(mktemp -d "${TMPDIR:-/tmp}/usher.XXXXXX")"
    local php_sock="${WORK_DIR}/php-fpm.sock"
    local php_conf="${WORK_DIR}/php-fpm.conf"
    local php_log="${WORK_DIR}/php-fpm.log"
    local caddyfile="${WORK_DIR}/Caddyfile"
    PHP_PID_FILE="${WORK_DIR}/php-fpm.pid"

    trap cleanup EXIT
    trap 'exit 130' INT
    trap 'exit 143' TERM

    # ── Optional PHP-FPM ──────────────────────────────────────────────────────
    # Resolve a php-fpm binary. /usr/sbin holds the FPM binaries on Debian/Ubuntu
    # but is often absent from the PATH of a GUI-launched process, so fall back to
    # probing it directly (matching install.sh) before giving up.
    local php_enabled=false php_fpm_bin=""
    if command -v php >/dev/null 2>&1; then
        local php_ver cand
        php_ver="$(php -r 'echo PHP_MAJOR_VERSION.".".PHP_MINOR_VERSION;')"
        for cand in "php-fpm${php_ver}" php-fpm \
                    "/usr/sbin/php-fpm${php_ver}" /usr/sbin/php-fpm; do
            if command -v "$cand" >/dev/null 2>&1; then
                php_fpm_bin="$cand"
                break
            fi
        done
    fi

    if [[ -n "$php_fpm_bin" ]]; then
        cat > "$php_conf" <<EOF
[global]
pid = ${PHP_PID_FILE}
error_log = ${php_log}
daemonize = yes

[www]
listen = ${php_sock}
pm = static
pm.max_children = 2
EOF
        echo "Starting ${php_fpm_bin}..."
        if "$php_fpm_bin" -y "$php_conf"; then
            php_enabled=true
        else
            echo "Warning: ${php_fpm_bin} failed to start; serving static files only." >&2
        fi
    else
        echo "Note: no PHP-FPM found; serving static files only."
    fi

    # ── TLS ───────────────────────────────────────────────────────────────────
    local tls_config
    if [[ -f "$CERT_FILE" && -f "$KEY_FILE" ]]; then
        tls_config="tls \"${CERT_FILE}\" \"${KEY_FILE}\""

        # Warn if the cert expires within 30 days and offer to regenerate.
        if command -v openssl >/dev/null 2>&1; then
            local expiry days_left
            expiry="$(openssl x509 -enddate -noout -in "$CERT_FILE" 2>/dev/null | cut -d= -f2)" || true
            if [[ -n "$expiry" ]]; then
                days_left=$(( ( $(date -d "$expiry" +%s) - $(date +%s) ) / 86400 ))
                if (( days_left < 30 )); then
                    local msg
                    if (( days_left <= 0 )); then
                        msg="TLS certificate has expired."
                    else
                        msg="TLS certificate expires in ${days_left} day(s)."
                    fi
                    local do_renew=false
                    if command -v zenity >/dev/null 2>&1; then
                        zenity --question \
                            --title="usher — certificate expiry" \
                            --text="${msg}\nRegenerate now with mkcert?" \
                            2>/dev/null && do_renew=true || true
                    else
                        notify "usher" "${msg} Renew: re-run install.sh, or mkcert -cert-file ${CERT_FILE} -key-file ${KEY_FILE} localhost 127.0.0.1 ::1"
                    fi
                    if [[ "$do_renew" == true ]]; then
                        if command -v mkcert >/dev/null 2>&1; then
                            mkcert -cert-file "$CERT_FILE" -key-file "$KEY_FILE" \
                                localhost 127.0.0.1 ::1 "$(hostname)"
                        else
                            notify "usher" "mkcert not found — install it and re-run install.sh to renew."
                        fi
                    fi
                fi
            fi
        fi
    else
        tls_config="tls internal"
        echo "Note: no certificate at ${CERT_FILE}; using Caddy's internal CA."
    fi

    # ── PHP route block (only when PHP-FPM is up) ─────────────────────────────
    local php_block=""
    if [[ "$php_enabled" == true ]]; then
        php_block="
    try_files {path} {path}/index.php index.php

    @phpFiles path *.php
    handle @phpFiles {
        php_fastcgi unix/${php_sock}
    }
"
    fi

    # ── Custom MIME types from config (MIME_TYPES array: "ext:content/type") ──
    local mime_block=""
    if [[ -v MIME_TYPES && ${#MIME_TYPES[@]} -gt 0 ]]; then
        for _entry in "${MIME_TYPES[@]}"; do
            mime_block+="    mime ${_entry%%:*} ${_entry#*:}"$'\n'
        done
    fi

    # ── Extra site-block directives from config (CADDY_EXTRA string) ──────────
    local extra_block="${CADDY_EXTRA:-}"

    # ── Caddyfile ─────────────────────────────────────────────────────────────
    cat > "$caddyfile" <<EOF
{
    auto_https disable_redirects
    admin off
}

https://127.0.0.1:${PORT} {
    ${tls_config}
    root * "${root}"

    log {
        output stdout
        format json
    }
${php_block}${mime_block}
    file_server

    header {
        Access-Control-Allow-Origin *
        Access-Control-Allow-Methods "GET, POST, OPTIONS"
        Access-Control-Allow-Headers *
    }

    @options method OPTIONS
    respond @options 204
${extra_block}
}
EOF

    # ── Launch Caddy in the background so signals reach the trap cleanly ───────
    notify "usher" "Serving ${root} at https://127.0.0.1:${PORT}"
    caddy run --config "$caddyfile" --adapter caddyfile \
        > >(jq --unbuffered -r \
            '"[\(.ts | todate)] [36m[\(.request.method)][0m \(.request.uri)  [[32m\(.status)[0m]"' \
            2>/dev/null) &
    CADDY_PID=$!

    mkdir -p "$RUN_DIR"
    # $BASHPID, not $$: when serve runs backgrounded (the GUI path) $$ is the
    # parent shell that is about to exit, so the PID file would point at a dead
    # process and --stop/--status would lose track of the server.
    echo "$BASHPID" > "${RUN_DIR}/usher-${PORT}.pid"
    write_state running "$root" "$PORT" "$CADDY_PID"
    local count; count=$(list_running 2>/dev/null | wc -l) || count=0
    launcher_badge "$count"
    wait "$CADDY_PID"
}

# ── Entry point ──────────────────────────────────────────────────────────────

main() {
    local root PORT_EXPLICIT=false

    # --port must come before any other flag or path argument.
    if [[ "${1:-}" == "--port" ]]; then
        [[ -z "${2:-}" ]] && { echo "usher: --port requires a port number" >&2; exit 1; }
        PORT="$2"
        PORT_EXPLICIT=true
        shift 2
    fi

    case "${1:-}" in
        -h|--help)      usage; exit 0 ;;
        --stop)         stop_server "${2:-}"; exit 0 ;;
        --status)       status; exit 0 ;;
        --set-default)  set_default "${2:-}"; exit 0 ;;
        --pick)         root="$(pick_dir)" || exit 0; [[ -z "$root" ]] && exit 0 ;;
        --new-bookmark) new_bookmark; exit 0 ;;
        --bookmark)     set_bookmark "${2:-}" "${3:-}"; exit 0 ;;
        --unbookmark)   remove_bookmark "${2:-}"; exit 0 ;;
        --bookmarks)           list_bookmarks; exit 0 ;;
        install-extension)   install_extension; exit 0 ;;
        uninstall-extension) uninstall_extension; exit 0 ;;
        -*)             echo "usher: unknown option: $1" >&2; usage; exit 1 ;;
        "")
            if [[ -t 1 ]]; then
                # Terminal: serve default or CWD directly.
                root="${DEFAULT_ROOT:-$PWD}"
            else
                # GUI (launcher click): show the control panel.
                gui_panel
                exit 0
            fi
            ;;
        *)
            local bm_path
            bm_path="$(lookup_bookmark "$1")" && root="$bm_path" || root="$1"
            ;;
    esac
    serve "$root"
}

main "$@"
