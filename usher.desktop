[Desktop Entry]
Version=1.0
Name=Usher
GenericName=Local HTTPS dev server
Comment=Serve the default folder over HTTPS (Caddy + PHP) in the background
Exec=usher
Terminal=false
Type=Application
Categories=Development;WebDevelopment;
Icon=usher
StartupNotify=false
Actions=serve-folder;set-default;stop;

[Desktop Action serve-folder]
Name=Serve a folder…
Exec=usher --pick

[Desktop Action set-default]
Name=Set default folder…
Exec=usher --set-default

[Desktop Action stop]
Name=Stop server
Exec=usher --stop
